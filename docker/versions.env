# Cepheus Build — single source of truth for build-env toolchain pins.
#
# The provisioners (docker/macos/provision.sh, docker/windows/oem/install.bat)
# read this file so every build environment installs the SAME toolchain. Keep
# docker/linux/Dockerfile ARGs in sync with these values — CI asserts it
# (tests/test_provisioning_pins.py). A drifted `brew`/`choco` "latest" already
# broke a build once (Flutter 3.44.2 vs the pinned 3.41.7); this manifest is
# the fix.
#
# Plain KEY=VALUE only (no quotes, no spaces): both POSIX `source` and the
# Windows `for /f` parser read it.
CBUILD_FLUTTER_VERSION=3.41.7
CBUILD_GO_VERSION=1.26.4
CBUILD_RUST_VERSION=1.95.0
CBUILD_COCOAPODS_VERSION=1.16.2
CBUILD_PYTHON_VERSION=3.12
CBUILD_JDK_MAJOR=17
